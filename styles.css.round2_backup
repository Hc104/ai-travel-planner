    transition: width var(--transition-slow);
}

.bar-fill.time {
    background: linear-gradient(90deg, var(--primary-400), var(--primary-600));
}

.bar-fill.cost {
    background: linear-gradient(90deg, var(--accent-400), var(--danger-500));
}

.bar-fill.comfort {
    background: linear-gradient(90deg, var(--secondary-400), var(--secondary-600));
}

.bar-value {
    font-size: var(--font-xs);
    font-weight: 600;
    color: var(--text-700);
    min-width: 60px;
}

.train-name {
    font-size: var(--font-xs);
    color: var(--primary-600);
    background: rgba(139, 92, 246, 0.08);
    padding: 1px 6px;
    border-radius: 4px;
    font-weight: 500;
}

.tag-transfer {
    background: rgba(234, 88, 12, 0.1);
    color: #ea580c;
}

.estimate-tag {
    font-size: 0.65rem;
    color: var(--accent-500);
    background: rgba(245, 158, 11, 0.1);
    padding: 1px 6px;
    border-radius: 4px;
    font-weight: 500;
}

.station-info {
    font-size: var(--font-xs);
    color: var(--text-500);
    margin-top: 2px;
}

.locate-icon {
    margin-right: 4px;
    font-style: normal;
}

.locating {
    color: var(--text-400);
    animation: locatePulse 1.5s ease-in-out infinite;
}

@keyframes locatePulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}

.attractions-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
}

.attraction-item {
    display: flex;
    gap: var(--spacing-lg);
    padding: var(--spacing-lg);
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    transition: all var(--transition-normal);
    cursor: pointer;
    position: relative;
    border: 1px solid transparent;
}

.attraction-item:hover {
    transform: translateX(6px);
    box-shadow: var(--shadow-lg);
    border-color: var(--primary-200);
    background: var(--bg-secondary);
}

.attraction-arrow {
    position: absolute;
    right: var(--spacing-lg);
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-400);
    font-size: 1.2rem;
    opacity: 0;
    transition: all var(--transition-fast);
}

.attraction-item:hover .attraction-arrow {
    opacity: 1;
    color: var(--primary-500);
}

.attraction-badge {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, var(--primary-500), var(--primary-400));
    color: white;
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    flex-shrink: 0;
    box-shadow: var(--shadow-md);
    transition: transform var(--transition-fast);
}

.attraction-item:hover .attraction-badge {
