﻿/* ========================================
   旅游智能规划助手 - 样式文件 (Impeccable优化版)
   ======================================== */

/* ========================================
   SPA Planner 作用域
   ======================================== */
#planner-section {
    display: none;
    position: relative;
    z-index: 1;
    min-height: 100vh;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1), transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
}

#planner-section.visible {
    display: block;
}

#planner-section.entered {
    opacity: 1;
    transform: translateY(0);
}

/* Planner 元素 stagger 入场 */
#planner-section .app-header {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.45s ease, transform 0.45s ease;
}
#planner-section.entered .app-header {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.05s;
}

#planner-section .input-section {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.45s ease, transform 0.45s ease;
}
#planner-section.entered .input-section {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.13s;
}

#planner-section .result-section {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.45s ease, transform 0.45s ease;
}
#planner-section.entered .result-section {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.21s;
}

#planner-section .app-footer {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.45s ease, transform 0.45s ease;
}
#planner-section.entered .app-footer {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.29s;
}

.page-loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: linear-gradient(180deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 0.5s cubic-bezier(0.76, 0, 0.24, 1);
}

.page-loader.hidden {
    opacity: 0;
    pointer-events: none;
}

.page-loader-spinner {
    width: 60px;
    height: 60px;
    border: 3px solid rgba(255, 255, 255, 0.15);
    border-top-color: rgba(255, 255, 255, 0.8);
    border-radius: 50%;
    animation: loader-spin 0.8s linear infinite;
}

/* 规划页面入场动画 */
@keyframes slideUpIn {
    from {
        opacity: 0;
        transform: translateY(40px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes loader-spin {
    to {
        transform: rotate(360deg);
    }
}

:root {
    --primary-50: #eff6ff;
    --primary-100: #dbeafe;
    --primary-200: #bfdbfe;
    --primary-300: #93c5fd;
    --primary-400: #60a5fa;
    --primary-500: #3b82f6;
    --primary-600: #2563eb;
    --primary-700: #1d4ed8;
    --primary-800: #1e40af;
    --primary-900: #1e3a8a;
    
    --secondary-50: #f0fdf4;
    --secondary-100: #dcfce7;
    --secondary-200: #bbf7d0;
    --secondary-300: #86efac;
    --secondary-400: #4ade80;
    --secondary-500: #22c55e;
    --secondary-600: #16a34a;
    --secondary-700: #15803d;
    
    --accent-50: #fffbeb;
    --accent-100: #fef3c7;
    --accent-200: #fde68a;
    --accent-300: #fcd34d;
    --accent-400: #fbbf24;
    --accent-500: #f59e0b;
    --accent-600: #d97706;
    
    --danger-50: #fef2f2;
    --danger-100: #fee2e2;
    --danger-200: #fecaca;
    --danger-500: #ef4444;
    
    --blue-50: #eff6ff;
    --blue-100: #dbeafe;
    --blue-200: #bfdbfe;
    --blue-300: #93c5fd;
    --blue-400: #60a5fa;
    --blue-500: #3b82f6;
    --blue-600: #2563eb;
    
    --bg-primary: #fafbfc;
    --bg-secondary: #ffffff;
    --bg-tertiary: #f1f5f9;
    
    --text-900: #0f172a;
    --text-800: #1e293b;
    --text-700: #334155;
    --text-600: #475569;
    --text-500: #64748b;
    --text-400: #94a3b8;
    --text-300: #cbd5e1;
    
    --border-200: #e2e8f0;
    --border-300: #cbd5e1;
    --border-400: #94a3b8;
    
    --shadow-xs: 0 1px 2px 0 rgba(0, 0, 0, 0.03);
    --shadow-sm: 0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px -1px rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.08), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -4px rgba(0, 0, 0, 0.03);
    --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.08), 0 8px 10px -6px rgba(0, 0, 0, 0.03);
    
    --radius-xs: 6px;
    --radius-sm: 10px;
    --radius-md: 14px;
    --radius-lg: 18px;
    --radius-xl: 24px;
    --radius-full: 9999px;
    
    --spacing-xs: 4px;
    --spacing-sm: 8px;
    --spacing-md: 12px;
    --spacing-lg: 16px;
    --spacing-xl: 24px;
    --spacing-2xl: 32px;
    --spacing-3xl: 48px;
    
    --transition-fast: 0.15s ease;
    --transition-normal: 0.25s ease;
    --transition-slow: 0.4s ease;
    
    --font-xs: 0.75rem;
    --font-sm: 0.875rem;
    --font-base: 1rem;
    --font-lg: 1.125rem;
    --font-xl: 1.25rem;
    --font-2xl: 1.5rem;
    --font-3xl: 1.875rem;
    --font-4xl: 2.25rem;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', -apple-system, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 50%, #e0e7ff 100%);
    min-height: 100vh;
    color: var(--text-800);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
}

.app-container {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--spacing-xl);
    min-height: 100vh;
    animation: slideUpIn 0.6s 0.2s cubic-bezier(0.76, 0, 0.24, 1) both;
    display: flex;
    flex-direction: column;
}

.app-header {
    text-align: center;
    padding: var(--spacing-3xl) var(--spacing-xl);
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
    margin-bottom: var(--spacing-xl);
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(226, 232, 240, 0.4);
    display: flex;
    flex-direction: column;
    align-items: center;
}

.app-header::before {
    content: '';
    position: absolute;
    top: -60%;
    right: -30%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.08) 0%, transparent 70%);
    border-radius: 50%;
}

.app-header::after {
    content: '';
    position: absolute;
    top: -40%;
    left: -20%;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(147, 197, 253, 0.06) 0%, transparent 60%);
    border-radius: 50%;
}



.app-header h1 {
    font-size: var(--font-3xl);
    font-weight: 700;
    background: linear-gradient(135deg, var(--primary-600), var(--primary-800));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.02em;
    position: relative;
    z-index: 1;
    line-height: 1.2;
}

.app-header .subtitle {
    color: var(--text-500);
    font-size: var(--font-lg);
    font-weight: 400;
    position: relative;
    z-index: 1;
    padding: var(--spacing-sm) var(--spacing-xl);
    background: rgba(59, 130, 246, 0.04);
    border-radius: var(--radius-full);
    border: 1px solid rgba(59, 130, 246, 0.08);
    display: inline-block;
    margin-top: var(--spacing-sm);
}

.section-icon {
    color: var(--primary-500);
    width: 18px;
    height: 18px;
    margin-right: var(--spacing-sm);
    flex-shrink: 0;
}

.checkbox-icon {
    color: var(--text-500);
    width: 16px;
    height: 16px;
    margin-right: var(--spacing-xs);
    flex-shrink: 0;
}

.btn-icon {
    width: 16px;
    height: 16px;
    margin-right: var(--spacing-xs);
}

.main-content {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: var(--spacing-xl);
    flex: 1;
    min-height: 0;
    align-items: start;
}

.input-section {
    position: sticky;
    top: 0;
    max-height: calc(100vh - 180px);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border-300) transparent;
}

.input-section::-webkit-scrollbar {
    width: 6px;
}

.input-section::-webkit-scrollbar-track {
    background: transparent;
}

.input-section::-webkit-scrollbar-thumb {
    background: var(--border-300);
    border-radius: var(--radius-full);
}

.result-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xl);
    max-height: calc(100vh - 180px);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border-300) transparent;
    padding-right: 4px;
    scroll-margin-top: 12px;
}

/* 结果区域高亮脉冲：提交后提示用户有新内容 */
.result-highlight {
    animation: result-pulse 0.6s ease;
}

@keyframes result-pulse {
    0% { background-color: var(--bg-secondary); }
    30% { background-color: rgba(59, 130, 246, 0.06); }
    100% { background-color: var(--bg-secondary); }
}

.result-section::-webkit-scrollbar {
    width: 6px;
}

.result-section::-webkit-scrollbar-track {
    background: transparent;
}

.result-section::-webkit-scrollbar-thumb {
    background: var(--border-300);
    border-radius: var(--radius-full);
}

.card {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06), 0 1px 3px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(226, 232, 240, 0.5);
    transition: box-shadow var(--transition-normal), transform var(--transition-fast), border-color var(--transition-fast);
}

.card:hover {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1), 0 4px 12px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
    border-color: rgba(59, 130, 246, 0.2);
}

.result-card {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06), 0 1px 3px rgba(0, 0, 0, 0.04);
    margin-bottom: var(--spacing-xl);
    animation: cardFadeIn var(--transition-slow) cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid rgba(226, 232, 240, 0.5);
    transition: box-shadow var(--transition-normal), transform var(--transition-fast);
}

.result-card:hover {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1), 0 4px 12px rgba(0, 0, 0, 0.06);
}

@keyframes cardFadeIn {
    from {
        opacity: 0;
        transform: translateY(16px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.input-section .card h2 {
    font-size: var(--font-xl);
    font-weight: 600;
    color: var(--text-800);
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-md);
    border-bottom: 2px solid var(--primary-200);
    position: relative;
}

.input-section .card h2::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 40px;
    height: 2px;
    background: var(--primary-500);
    border-radius: var(--radius-full);
}

.form-group {
    margin-bottom: var(--spacing-xl);
}

.form-group label {
    display: block;
    font-weight: 600;
    color: var(--text-700);
    margin-bottom: var(--spacing-sm);
    font-size: var(--font-sm);
}

.form-group input[type="text"],
.form-group input[type="number"],
.form-group input[type="date"] {
    width: 100%;
    padding: var(--spacing-md) var(--spacing-lg);
    border: 2px solid var(--border-200);
    border-radius: var(--radius-sm);
    font-size: var(--font-base);
    font-family: inherit;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast), transform var(--transition-fast);
    background: var(--bg-primary);
    color: var(--text-800);
}

.form-group input:focus {
    outline: none;
    border-color: var(--primary-500);
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
    background: var(--bg-secondary);
    transform: translateY(-1px);
}

.form-group input:hover:not(:focus) {
    border-color: var(--border-300);
    background: var(--bg-secondary);
}

.form-group input::placeholder {
    color: var(--text-400);
}

.preference-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-md);
}

.checkbox-label {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-md) var(--spacing-lg);
    background: var(--bg-primary);
    border: 2px solid transparent;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all var(--transition-fast);
    font-size: var(--font-sm);
    font-weight: 500;
    color: var(--text-700);
}

.checkbox-label:hover {
    background: var(--primary-50);
    border-color: var(--primary-200);
}

.checkbox-label input[type="checkbox"] {
    width: 18px;
    height: 18px;
    accent-color: var(--primary-500);
    cursor: pointer;
}

.checkbox-label input[type="checkbox"]:checked + span {
    color: var(--primary-600);
}

.btn-primary {
    width: 100%;
    padding: var(--spacing-lg) var(--spacing-xl);
    background: linear-gradient(135deg, var(--primary-500), var(--primary-600));
    color: white;
    border: none;
    border-radius: var(--radius-sm);
    font-size: var(--font-lg);
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: all var(--transition-fast);
    margin-top: var(--spacing-md);
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 14px rgba(59, 130, 246, 0.35);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-xs);
}

.btn-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.15), transparent);
    transition: left var(--transition-slow);
}

.btn-primary:hover::before {
    left: 100%;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(59, 130, 246, 0.45);
    background: linear-gradient(135deg, var(--primary-600), var(--primary-700));
}

.btn-primary:active {
    transform: translateY(0) scale(0.98);
    box-shadow: 0 2px 8px rgba(59, 130, 246, 0.3);
}

.btn-primary:focus {
    outline: none;
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.3);
}

.btn-primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
}

/* 按钮 Loading 状态 */
.btn-primary.loading {
    cursor: not-allowed;
    padding-left: 44px;
}

.btn-spinner {
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    display: none;
}

.btn-primary.loading .btn-spinner {
    display: block;
}

@keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

/* 骨架屏样式 */
.skeleton-card {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06), 0 1px 3px rgba(0, 0, 0, 0.04);
    margin-bottom: var(--spacing-xl);
    position: relative;
    border: 1px solid rgba(226, 232, 240, 0.5);
    overflow: hidden;
}

/* 右上角图标占位小圆点 */
.skeleton-card::after {
    content: '';
    position: absolute;
    top: var(--spacing-xl);
    right: var(--spacing-xl);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--skeleton-base);
    animation: pulse 1.5s ease-in-out infinite;
}

.skeleton-bar {
    width: var(--width, 100%);
    height: var(--height, 16px);
    background: var(--skeleton-base);
    border-radius: 4px;
    margin-bottom: 12px;
    animation: pulse 1.5s ease-in-out infinite;
    will-change: opacity;
}

.skeleton-bar:last-child {
    margin-bottom: 0;
}

/* 脉冲动画 */
:root {
    --skeleton-base: rgba(148, 163, 184, 0.3);
}

@keyframes pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.6; }
}

/* 内联表单验证错误提示 */
.field-error {
    display: none;
    font-size: 0.75rem;
    color: #ef4444;
    margin-top: 4px;
    line-height: 1.4;
    animation: errorSlideIn 0.25s ease;
}

.field-error.visible {
    display: block;
}

@keyframes errorSlideIn {
    from {
        opacity: 0;
        transform: translateY(-4px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.input-error {
    border-color: #ef4444 !important;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1) !important;
}

/* 城市选择器错误状态 */
.city-selector .input-error,
.city-selector-input.input-error {
    border-color: #ef4444 !important;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1) !important;
}

.welcome-tip {
    text-align: center;
    padding: var(--spacing-3xl) var(--spacing-xl);
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(226, 232, 240, 0.5);
    transition: box-shadow var(--transition-normal);
}

.welcome-tip:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
}

.welcome-tip .tip-icon {
    font-size: 4rem;
    margin-bottom: var(--spacing-xl);
    opacity: 0.8;
}

.loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    transition: opacity var(--transition-normal);
}

.loading-overlay.hidden {
    opacity: 0;
    pointer-events: none;
}

.loading-spinner {
    width: 48px;
    height: 48px;
    border: 4px solid var(--border-200);
    border-top-color: var(--primary-500);
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

.loading-text {
    margin-top: var(--spacing-lg);
    color: var(--text-500);
    font-size: var(--font-base);
    font-weight: 500;
}

.welcome-tip h3 {
    color: var(--text-800);
    margin-bottom: var(--spacing-md);
    font-size: var(--font-2xl);
    font-weight: 600;
}

.welcome-tip p {
    color: var(--text-500);
    font-size: var(--font-base);
    max-width: 400px;
    margin: 0 auto;
}

.result-card h3 {
    font-size: var(--font-xl);
    font-weight: 600;
    color: var(--text-800);
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-md);
    border-bottom: 2px solid var(--border-200);
    position: relative;
}

.result-card h3::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 30px;
    height: 2px;
    background: var(--primary-500);
    border-radius: var(--radius-full);
}

.transport-tabs {
    display: flex;
    gap: 0;
    margin-bottom: var(--spacing-xl);
    background: rgba(139, 92, 246, 0.06);
    border-radius: var(--radius-md);
    padding: 4px;
}

.transport-tab {
    flex: 1;
    text-align: center;
    padding: var(--spacing-md) var(--spacing-lg);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: var(--font-sm);
    font-weight: 500;
    color: var(--text-500);
    transition: all var(--transition-fast);
    user-select: none;
}

.transport-tab:hover {
    color: var(--primary-600);
    background: rgba(139, 92, 246, 0.08);
}

.transport-tab.active {
    background: var(--primary-500);
    color: #fff;
    font-weight: 600;
    box-shadow: 0 4px 12px rgba(139, 92, 246, 0.35);
}

.transport-summary {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
    padding: var(--spacing-lg);
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.06), rgba(59, 130, 246, 0.06));
    border-radius: var(--radius-md);
    margin-bottom: var(--spacing-xl);
    border-left: 3px solid var(--primary-500);
