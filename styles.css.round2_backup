   预算每日明细卡片
   ======================================== */
.budget-daily-breakdown {
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-xl);
    border-top: 1px solid var(--border-200);
}

.budget-daily-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-lg);
}

.budget-daily-title {
    font-size: var(--font-base);
    font-weight: 600;
    color: var(--text-700);
}

.budget-daily-total {
