    top: 38px;
    bottom: -2px;
    width: 2px;
    background: rgba(139, 92, 246, 0.1);
}

.step-number {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(139, 92, 246, 0.08);
