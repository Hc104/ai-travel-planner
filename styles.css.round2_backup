    font-size: var(--font-sm);
    margin-top: var(--spacing-xl);
}

.city-selector {
    position: relative;
}

.city-selector-input {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--spacing-md) var(--spacing-lg);
    border: 2px solid var(--border-200);
    border-radius: var(--radius-sm);
    font-size: var(--font-base);
    cursor: pointer;
    transition: all var(--transition-fast);
    background: var(--bg-primary);
    user-select: none;
    font-family: inherit;
    position: relative;
}

.city-selector-input::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--primary-500);
    transition: width var(--transition-normal), left var(--transition-normal);
    border-radius: var(--radius-full);
}

.city-selector-input:hover::after {
    width: 100%;
    left: 0;
}

.city-selector-input:hover {
    border-color: var(--primary-300);
    background: var(--primary-50);
    transform: translateY(-1px);
}

.city-selector-input:focus {
    outline: none;
    border-color: var(--primary-500);
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
    background: var(--bg-secondary);
}

.city-selector-input.active {
    border-color: var(--primary-500);
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
    background: var(--bg-secondary);
}

.city-placeholder {
    color: var(--text-400);
    font-size: var(--font-base);
}

.city-selector-input .city-value {
    color: var(--text-800);
    font-weight: 500;
}

.city-arrow {
    color: var(--text-400);
    transition: transform var(--transition-normal);
    flex-shrink: 0;
}

.city-selector-input.active .city-arrow {
    transform: rotate(180deg);
}

.city-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    z-index: 1000;
    display: none;
    overflow: hidden;
    max-height: 420px;
    border: 1px solid var(--border-200);
}

.city-dropdown.show {
    display: block;
    animation: dropdownSlideIn var(--transition-fast) cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes dropdownSlideIn {
    from { opacity: 0; transform: translateY(-8px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
}

.city-search-box {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-md) var(--spacing-lg);
    border-bottom: 1px solid var(--border-200);
    background: var(--bg-primary);
}

.search-icon {
    color: var(--text-400);
    flex-shrink: 0;
}

.city-search-input {
    flex: 1;
    border: none;
    outline: none;
    font-size: var(--font-sm);
    background: transparent;
    color: var(--text-800);
    font-family: inherit;
}

.city-search-input::placeholder {
    color: var(--text-400);
}

.city-search-results {
    display: none;
    max-height: 280px;
    overflow-y: auto;
}

.city-search-results.show {
    display: block;
}

.city-search-results .city-section {
    display: block;
}

.search-result-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-md) var(--spacing-lg);
    cursor: pointer;
    transition: background var(--transition-fast);
    font-size: var(--font-sm);
}

.search-result-item:hover {
    background: var(--primary-50);
}

.search-result-item .city-name {
    font-weight: 500;
    color: var(--text-800);
}

.search-result-item .city-province-tag {
    font-size: var(--font-xs);
    color: var(--text-500);
    background: var(--bg-tertiary);
    padding: 2px 8px;
    border-radius: var(--radius-full);
}

.search-result-item mark {
    color: var(--primary-600);
    background: rgba(139, 92, 246, 0.1);
    font-weight: 600;
    padding: 0 2px;
    border-radius: 2px;
}

.city-panel {
    max-height: 340px;
    overflow-y: auto;
    padding: var(--spacing-sm) 0;
}

.city-panel::-webkit-scrollbar {
    width: 6px;
}

.city-panel::-webkit-scrollbar-track {
    background: transparent;
}

.city-panel::-webkit-scrollbar-thumb {
    background: var(--border-300);
    border-radius: var(--radius-full);
}

.city-section {
    padding: 0 var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
}

.city-section-title {
    font-size: var(--font-xs);
    color: var(--text-400);
    font-weight: 600;
    padding: var(--spacing-sm) 0;
    position: sticky;
    top: 0;
    background: #fff;
    z-index: 1;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.city-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-sm);
}

.city-tag {
    padding: var(--spacing-sm) 4px;
    text-align: center;
    background: var(--bg-primary);
    border: 1px solid var(--border-200);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: var(--font-xs);
    color: var(--text-700);
    transition: all var(--transition-fast);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-weight: 500;
}

.city-tag:hover {
    background: var(--primary-50);
    border-color: var(--primary-300);
    color: var(--primary-600);
}

.city-tag.selected {
    background: linear-gradient(135deg, var(--primary-500), var(--primary-600));
    border-color: var(--primary-500);
    color: #fff;
    box-shadow: var(--shadow-sm);
}

/* ========================================
   支持城市标签（目的地选择器专用）
   ======================================== */
.supported-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-sm);
}

.supported-city-tag {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    background: var(--bg-primary);
    border: 1px solid var(--border-200);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
    position: relative;
    overflow: hidden;
}

.supported-city-tag:hover {
    background: var(--primary-50);
    border-color: var(--primary-300);
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.supported-city-tag.selected {
    background: linear-gradient(135deg, var(--primary-50), #e8f0fe);
    border-color: var(--primary-400);
    box-shadow: 0 0 0 2px var(--primary-200);
}

.supported-city-emoji {
    font-size: 20px;
    line-height: 1;
    flex-shrink: 0;
}

.supported-city-name {
    font-size: var(--font-sm);
    font-weight: 600;
    color: var(--text-800);
    flex-shrink: 0;
}

.supported-city-desc {
    font-size: var(--font-xs);
    color: var(--text-400);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.supported-city-badge {
    font-size: 10px;
    padding: 2px 6px;
    background: linear-gradient(135deg, #fef3c7, #fde68a);
    color: #92400e;
    border-radius: 10px;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
}

.city-section-divider {
    height: 1px;
    background: var(--border-100);
    margin: 8px var(--spacing-lg);
}

/* 移动端适配 */
@media (max-width: 640px) {
    .supported-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 6px;
    }
    .supported-city-tag {
        padding: 8px 10px;
        gap: 6px;
    }
    .supported-city-emoji {
        font-size: 18px;
    }
    .supported-city-name {
        font-size: 13px;
    }
    .supported-city-desc {
        display: none;
    }
}

.city-province-list {
    display: flex;
    flex-direction: column;
}

.province-group {
    border-bottom: 1px solid var(--border-100);
    padding: var(--spacing-sm) 0;
}

.province-name {
    font-size: var(--font-xs);
    color: var(--primary-700);
    font-weight: 600;
    padding: 4px 0;
}

.province-cities {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 4px 0;
}

.province-city-tag {
    padding: 4px 10px;
    background: var(--bg-primary);
    border-radius: var(--radius-xs);
    cursor: pointer;
    font-size: var(--font-xs);
    color: var(--text-700);
    transition: all var(--transition-fast);
    font-weight: 500;
}

.province-city-tag:hover {
    background: var(--primary-50);
    color: var(--primary-600);
}

@media (max-width: 1024px) {
    .main-content {
        grid-template-columns: 1fr;
    }

    .input-section {
        position: static;
        max-height: none;
    }

    .result-section {
        max-height: none;
    }
}

@media (max-width: 640px) {
    .result-section {
        scroll-margin-top: 120px;
    }

    .app-container {
        padding: var(--spacing-lg);
    }

    .app-header {
        padding: var(--spacing-xl);
    }

    .app-header h1 {
        font-size: var(--font-2xl);
    }

    .card {
        padding: var(--spacing-lg);
    }

    .result-card {
        padding: var(--spacing-lg);
    }

    .preference-options {
        grid-template-columns: 1fr;
    }

    .budget-content {
        flex-direction: column;
        align-items: flex-start;
    }

    .pie-chart-container {
        width: 180px;
        height: 180px;
    }

    .attraction-item {
        flex-direction: row;
        align-items: center;
        gap: var(--spacing-md);
    }

    .attraction-image {
        width: 80px;
        height: 60px;
    }

    .attraction-badge {
        width: 100%;
        height: auto;
        flex-direction: row;
        gap: var(--spacing-sm);
        padding: var(--spacing-md) var(--spacing-lg);
    }

    .attraction-price {
        text-align: left;
        margin-top: var(--spacing-sm);
    }

    .city-grid {
        grid-template-columns: repeat(3, 1fr);
    }

    .plan-metrics {
        flex-wrap: wrap;
        gap: var(--spacing-md);
    }

    .transport-plan.recommended::after {
        top: 8px;
        right: -24px;
        padding: 1px 24px;
        font-size: 0.65rem;
    }
}

@media (max-width: 480px) {
    .app-container {
        padding: var(--spacing-md);
    }

    .app-header {
        padding: var(--spacing-lg);
    }

    .app-header h1 {
        font-size: var(--font-xl);
    }

    .app-header .subtitle {
        font-size: var(--font-base);
    }

    .city-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .food-list {
        grid-template-columns: 1fr;
    }

    .budget-details {
        grid-template-columns: repeat(2, 1fr);
    }

    .budget-daily-cards {
        grid-template-columns: repeat(2, 1fr);
    }

    .budget-hotel-detail {
        flex-wrap: wrap;
    }

    .budget-hotel-text {
        min-width: 100%;
        order: 1;
    }
}

/* ========================================
   历史规划卡片样式
   ======================================== */
.history-section {
    margin-top: var(--spacing-xl);
    padding: var(--spacing-xl);
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    border: 1px solid rgba(226, 232, 240, 0.6);
}

.history-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-md);
    border-bottom: 2px solid var(--border-200);
    position: relative;
}

.history-header::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 30px;
    height: 2px;
    background: var(--primary-500);
    border-radius: var(--radius-full);
}

.history-header h4 {
    font-size: var(--font-lg);
    font-weight: 600;
    color: var(--text-800);
}

.history-clear-btn {
    padding: var(--spacing-sm) var(--spacing-md);
    background: var(--danger-50);
    color: var(--danger-500);
    border: 1px solid var(--danger-200);
    border-radius: var(--radius-sm);
    font-size: var(--font-xs);
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-fast);
}

.history-clear-btn:hover {
    background: var(--danger-100);
    border-color: var(--danger-300);
}

#historyList {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
}

.history-item {
    padding: var(--spacing-lg);
    background: var(--bg-primary);
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    transition: all var(--transition-fast);
    cursor: pointer;
    position: relative;
}

.history-item:hover {
    background: var(--bg-secondary);
    border-color: var(--primary-200);
    box-shadow: var(--shadow-sm);
    transform: translateX(4px);
}

.history-route {
    font-weight: 600;
    font-size: var(--font-base);
    color: var(--text-800);
    margin-bottom: var(--spacing-xs);
}

.history-info {
    font-size: var(--font-sm);
    color: var(--text-500);
    margin-bottom: var(--spacing-xs);
}

.history-meta {
    font-size: var(--font-sm);
    color: var(--text-500);
    margin-bottom: var(--spacing-xs);
}

.history-time {
    font-size: var(--font-xs);
    color: var(--text-400);
}

.history-date {
    font-size: var(--font-xs);
    color: var(--text-400);
}

/* history-delete styles moved to end of file - see .history-actions section */

.history-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 60%;
    background: var(--primary-200);
    border-radius: 0 var(--radius-full) var(--radius-full) 0;
    transition: background var(--transition-fast);
}

.history-item:hover::before {
    background: var(--primary-500);
}

/* ========================================
   天气卡片样式
   ======================================== */
.weather-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
}

.weather-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--spacing-lg);
}

.weather-day-card {
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    text-align: center;
    border: 1px solid transparent;
    transition: all var(--transition-normal);
}

.weather-day-card:hover {
    background: var(--bg-secondary);
    border-color: var(--primary-200);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
}

.weather-day-card.today {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.08), rgba(59, 130, 246, 0.06));
    border-color: rgba(139, 92, 246, 0.2);
}

.weather-date {
    font-size: var(--font-base);
    font-weight: 600;
    color: var(--text-800);
    margin-bottom: 4px;
}

.weather-week {
    font-size: var(--font-xs);
    color: var(--text-500);
    margin-bottom: var(--spacing-md);
}

.weather-icon-row {
    margin-bottom: var(--spacing-md);
}

.weather-icon-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-xs);
}

.weather-icon-item .icon {
    font-size: 2.5rem;
    opacity: 0.9;
}

.weather-icon-item .label {
    font-size: var(--font-sm);
    color: var(--text-700);
    font-weight: 500;
}

.weather-temp {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-sm);
}

.temp-high {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--danger-500);
}

.temp-low {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--blue-500);
}

.temp-separator {
    color: var(--text-400);
    font-size: 1rem;
}

.weather-apparent-temp {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-xs);
    font-size: var(--font-xs);
    color: var(--text-500);
    margin-bottom: var(--spacing-sm);
}

.apparent-label {
    color: var(--text-400);
}

.apparent-high {
    color: var(--danger-400);
}

.apparent-low {
    color: var(--blue-400);
}

.weather-wind {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    font-size: var(--font-xs);
    color: var(--text-500);
    margin-bottom: var(--spacing-sm);
}

.wind-icon {
    font-size: 0.8rem;
}

.weather-extra {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-md);
    font-size: var(--font-xs);
    color: var(--text-500);
    margin-bottom: var(--spacing-sm);
}

.precip-info {
    display: flex;
    align-items: center;
    gap: 2px;
}

.uv-info {
    display: flex;
    align-items: center;
    gap: 2px;
}

.weather-desc {
    font-size: var(--font-xs);
    color: var(--text-500);
    padding-top: var(--spacing-sm);
    border-top: 1px solid var(--border-200);
}

.weather-loading,
.weather-error {
    text-align: center;
    padding: var(--spacing-2xl);
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
}

.weather-loading .loading-icon,
.weather-error .error-icon {
    font-size: 3rem;
    margin-bottom: var(--spacing-md);
}

.weather-loading div:last-child,
.weather-error .error-text {
    font-size: var(--font-sm);
    color: var(--text-500);
}

/* 出行建议 */
.weather-advice {
    margin-top: var(--spacing-xl);
}

.weather-advice-title {
    font-size: var(--font-sm);
    font-weight: 600;
    color: var(--text-700);
    margin-bottom: var(--spacing-md);
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
}

.weather-advice-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
}

.weather-advice-item {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-sm);
    padding: var(--spacing-md);
    background: rgba(251, 191, 36, 0.06);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--accent-500);
}

.weather-advice-item .advice-icon {
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 2px;
}

.weather-advice-item .advice-text {
    font-size: var(--font-xs);
    color: var(--text-700);
    line-height: 1.6;
}

/* ========================================
   酒店住宿推荐卡片样式
   ======================================== */
#hotelContent {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
}

.hotel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--spacing-lg);
}

.hotel-card {
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    border: 1px solid transparent;
    transition: all var(--transition-normal);
    position: relative;
}

.hotel-card:hover {
    background: var(--bg-secondary);
    border-color: var(--primary-200);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
}

.hotel-card.recommended {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.06), rgba(59, 130, 246, 0.04));
    border-color: rgba(139, 92, 246, 0.2);
}

.hotel-name {
    font-size: var(--font-lg);
    font-weight: 600;
    color: var(--text-800);
    margin-bottom: var(--spacing-sm);
}

.hotel-tier {
    display: inline-block;
    padding: 2px 8px;
    border-radius: var(--radius-full);
    font-size: var(--font-xs);
    font-weight: 500;
    margin-bottom: var(--spacing-md);
}

.hotel-tier.economy {
    background: rgba(34, 197, 94, 0.1);
    color: var(--secondary-600);
}

.hotel-tier.comfort {
    background: rgba(59, 130, 246, 0.1);
    color: var(--blue-600);
}

.hotel-tier.business {
    background: rgba(139, 92, 246, 0.1);
    color: var(--primary-600);
}

.hotel-tier.luxury {
    background: rgba(245, 158, 11, 0.1);
    color: var(--accent-600);
}

.hotel-price {
    font-size: var(--font-xl);
    font-weight: 700;
    color: var(--primary-600);
    margin-bottom: var(--spacing-sm);
}

.hotel-price .per-night {
    font-size: var(--font-xs);
    font-weight: 400;
    color: var(--text-500);
}

.hotel-rating {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: var(--font-sm);
    color: var(--text-700);
    margin-bottom: var(--spacing-sm);
}

.hotel-location {
    font-size: var(--font-xs);
    color: var(--text-500);
    margin-bottom: var(--spacing-md);
    display: flex;
    align-items: center;
    gap: 4px;
}

.hotel-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-lg);
}

.hotel-tag {
    padding: 3px 8px;
    background: var(--primary-50);
    color: var(--primary-700);
    border-radius: var(--radius-full);
    font-size: var(--font-xs);
    font-weight: 500;
}

.hotel-actions {
    display: flex;
    gap: var(--spacing-sm);
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--border-200);
}

.btn-map,
.btn-book {
    flex: 1;
    padding: var(--spacing-sm) var(--spacing-md);
    text-align: center;
    border-radius: var(--radius-sm);
    font-size: var(--font-xs);
    font-weight: 500;
    text-decoration: none;
    transition: all var(--transition-fast);
}

.btn-map {
    background: var(--bg-tertiary);
    color: var(--text-700);
}

.btn-map:hover {
    background: var(--primary-50);
    color: var(--primary-600);
}

.btn-book {
    background: linear-gradient(135deg, var(--primary-500), var(--primary-600));
    color: white;
}

.btn-book:hover {
    background: linear-gradient(135deg, var(--primary-600), var(--primary-700));
    box-shadow: var(--shadow-sm);
}

/* ========================================
   响应式 - 天气和酒店卡片
   ======================================== */
@media (max-width: 640px) {
    .weather-grid {
        grid-template-columns: 1fr;
    }

    .hotel-grid {
        grid-template-columns: 1fr;
    }

    .weather-day-card {
        text-align: left;
    }

    .weather-day-card .weather-icon-row,
    .weather-day-card .weather-temp,
    .weather-day-card .weather-apparent-temp,
    .weather-day-card .weather-wind,
    .weather-day-card .weather-extra {
        justify-content: flex-start;
    }

    .weather-day-card .weather-icon-item {
        flex-direction: row;
        align-items: center;
    }

    .weather-day-card .weather-icon-item .icon {
        font-size: 2rem;
    }
}

/* ========================================
   推荐餐厅卡片样式
   ======================================== */
#restaurantList {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
}

.restaurant-loading,
.restaurant-empty {
    text-align: center;
    padding: var(--spacing-2xl);
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    font-size: var(--font-sm);
    color: var(--text-500);
}

.rest-card {
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    border: 1px solid transparent;
    transition: all var(--transition-normal);
    cursor: pointer;
    position: relative;
}

.rest-card:hover {
    background: var(--bg-secondary);
    border-color: var(--secondary-200);
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
}

.rest-card-header {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
}

.rest-card-num {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, var(--secondary-500), var(--secondary-600));
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: var(--font-sm);
    flex-shrink: 0;
}

.rest-card-info {
    flex: 1;
    min-width: 0;
}

.rest-card-name {
    font-size: var(--font-lg);
    font-weight: 600;
    color: var(--text-800);
    margin-bottom: var(--spacing-xs);
}

.rest-card-addr {
    font-size: var(--font-xs);
    color: var(--text-500);
    line-height: 1.5;
}

.rest-nav-btn {
    width: 36px;
    height: 36px;
    border: none;
    background: var(--danger-50);
    color: var(--danger-500);
    border-radius: 50%;
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
    flex-shrink: 0;
}

.rest-nav-btn:hover {
    background: var(--danger-100);
    transform: scale(1.1);
}

.rest-foods {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-md);
}

.rest-food-tag {
    padding: 3px 10px;
    background: var(--secondary-50);
    color: var(--secondary-600);
    border-radius: var(--radius-full);
    font-size: var(--font-xs);
    font-weight: 500;
}

.rest-card-footer {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
}

.rest-rating {
    font-size: var(--font-sm);
    font-weight: 600;
    color: var(--accent-500);
}

.rest-cost {
    font-size: var(--font-sm);
    font-weight: 600;
    color: var(--secondary-600);
}

.rest-dist {
    margin-left: auto;
    font-size: var(--font-xs);
    color: var(--text-400);
}

/* ========================================
   美食地图模态框样式
   ======================================== */
.food-map-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    backdrop-filter: blur(4px);
    animation: fadeIn var(--transition-fast);
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.food-map-panel {
    background: var(--bg-primary);
    border-radius: var(--radius-xl);
    width: 95%;
    max-width: 1000px;
    height: 85vh;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-2xl);
    animation: slideUp var(--transition-normal);
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(20px) scale(0.98);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

.food-map-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-lg) var(--spacing-xl);
    border-bottom: 1px solid var(--border-200);
}

.food-map-title {
    font-size: var(--font-lg);
    font-weight: 600;
    color: var(--text-800);
}

.food-map-close {
    width: 36px;
    height: 36px;
    border: none;
    background: var(--danger-50);
    color: var(--danger-500);
    border-radius: 50%;
    font-size: 1.5rem;
    font-weight: 300;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
}

.food-map-close:hover {
    background: var(--danger-100);
    transform: rotate(90deg);
}

.food-map-body {
    display: flex;
    flex: 1;
    overflow: hidden;
}

.food-map-container {
    flex: 1;
    min-width: 0;
    width: 100%;
    min-height: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
}

.food-shop-list {
    width: 280px;
    flex-shrink: 0;
    overflow-y: auto;
    padding: var(--spacing-md);
    background: var(--bg-secondary);
    border-left: 1px solid var(--border-200);
}

.food-shop-loading,
.food-shop-empty {
    padding: var(--spacing-lg);
    text-align: center;
    font-size: var(--font-xs);
    color: var(--text-500);
}

.food-shop-item {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-sm);
    padding: var(--spacing-md);
    background: var(--bg-primary);
    border-radius: var(--radius-md);
    margin-bottom: var(--spacing-sm);
    cursor: pointer;
    transition: all var(--transition-fast);
    border: 2px solid transparent;
}

.food-shop-item:hover {
    background: var(--bg-secondary);
    border-color: var(--secondary-200);
}

.food-shop-item.active {
    border-color: var(--secondary-500);
    background: rgba(34, 197, 94, 0.06);
}

.shop-num {
    width: 28px;
    height: 28px;
    background: var(--secondary-500);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: var(--font-xs);
    flex-shrink: 0;
}

.shop-info {
    flex: 1;
    min-width: 0;
}

.shop-name {
    font-size: var(--font-sm);
    font-weight: 600;
    color: var(--text-800);
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.shop-address {
    font-size: var(--font-xs);
    color: var(--text-500);
    margin-bottom: var(--spacing-xs);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.shop-specialties {
    display: flex;
    flex-wrap: wrap;
    gap: 3px;
    margin-bottom: var(--spacing-xs);
}

.shop-specialty-tag {
    padding: 2px 6px;
    background: var(--secondary-50);
    color: var(--secondary-600);
    border-radius: var(--radius-full);
    font-size: 10px;
    font-weight: 500;
}

.shop-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: var(--font-xs);
}

.shop-rating {
    color: var(--accent-500);
    font-weight: 600;
}

.shop-cost {
    color: var(--secondary-600);
    font-weight: 600;
}

.shop-dist {
    margin-left: auto;
    color: var(--text-400);
}

.shop-nav-btn {
    width: 30px;
    height: 30px;
    border: none;
    background: var(--danger-50);
    color: var(--danger-500);
    border-radius: 50%;
    font-size: 0.9rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
    flex-shrink: 0;
}

.shop-nav-btn:hover {
    background: var(--danger-100);
    transform: scale(1.1);
}

/* ========================================
   美食地图响应式
   ======================================== */
@media (max-width: 640px) {
    .food-map-panel {
        width: 95%;
        height: 90vh;
    }

    .food-map-body {
        flex-direction: column;
    }

    .food-map-container {
        flex: 1;
        min-height: 280px;
    }

    .food-shop-list {
        width: 100%;
        border-left: none;
        border-top: 1px solid var(--border-200);
        max-height: 300px;
    }

    .rest-card-header {
        flex-wrap: wrap;
    }

    .rest-nav-btn {
        margin-left: auto;
    }
}

/* ========================================
   地图选点器样式
   ======================================== */
.map-picker-section {
    margin-bottom: 20px;
}

.map-picker-tip {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 12px;
}

.map-picker-dialog {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: mapDialogFadeIn 0.2s ease-out;
}

@keyframes mapDialogFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.map-picker-dialog-content {
    background: var(--card-background);
    border-radius: var(--radius-lg);
    padding: 24px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
    min-width: 300px;
    text-align: center;
    animation: mapDialogSlideIn 0.25s ease-out;
}

@keyframes mapDialogSlideIn {
    from { transform: translateY(-20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}

.map-picker-dialog-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 8px;
}

.map-picker-dialog-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 16px;
}

.map-picker-dialog-buttons {
    display: flex;
    gap: 12px;
    margin-bottom: 12px;
}

.map-picker-btn {
    flex: 1;
    padding: 12px 16px;
    border: 2px solid var(--border-color);
    border-radius: var(--radius-sm);
    background: var(--background-color);
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-primary);
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
}

.map-picker-btn:hover {
    border-color: var(--primary-color);
    background: rgba(79, 70, 229, 0.05);
}

.map-picker-btn.departure-btn {
    background: linear-gradient(135deg, #10b981, #059669);
    border-color: #10b981;
    color: #fff;
}

.map-picker-btn.departure-btn:hover {
    background: linear-gradient(135deg, #059669, #047857);
    border-color: #059669;
}

.map-picker-btn.destination-btn {
    background: linear-gradient(135deg, #8b5cf6, #7c3aed);
    border-color: #8b5cf6;
    color: #fff;
}

.map-picker-btn.destination-btn:hover {
    background: linear-gradient(135deg, #7c3aed, #6d28d9);
    border-color: #7c3aed;
}

.map-picker-btn .btn-icon {
    font-weight: 700;
    font-size: 0.85rem;
}

.map-picker-cancel {
    width: 100%;
    padding: 8px;
    border: none;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 0.85rem;
    border-radius: var(--radius-sm);
    transition: background 0.2s;
}

.map-picker-cancel:hover {
    background: var(--background-color);
}/* ========================================
   History Item Actions (重命名/删除按钮)
   ======================================== */
.history-actions {
    display: flex;
    gap: 4px;
    opacity: 0;
    transition: opacity 0.2s;
}

.history-item:hover .history-actions {
    opacity: 1;
}

.history-rename {
    width: 28px;
    height: 28px;
    border: none;
    background: var(--primary-50);
    color: var(--primary-500);
    border-radius: 50%;
    font-size: 0.85rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
}

.history-rename:hover {
    background: var(--primary-100);
    transform: scale(1.1);
}

.history-delete {
    position: static;
    width: 28px;
    height: 28px;
    border: none;
    background: var(--danger-50);
    color: var(--danger-500);
    border-radius: 50%;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
}

.history-delete:hover {
    background: var(--danger-100);
    transform: scale(1.1);
}

/* ========================================
   天气预警横幅
   ======================================== */
.weather-warning-banner {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
    padding: var(--spacing-lg);
    background: linear-gradient(135deg, #fef2f2 0%, #fde8e8 100%);
    border: 1px solid #fecaca;
    border-radius: var(--radius-lg);
    margin-bottom: var(--spacing-lg);
}

.weather-warning-icon {
    font-size: 24px;
    flex-shrink: 0;
    margin-top: 2px;
}

.weather-warning-content {
    flex: 1;
}

.weather-warning-title {
    font-size: var(--font-sm);
    font-weight: 700;
    color: #dc2626;
    margin-bottom: var(--spacing-sm);
}

.weather-warning-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.weather-warning-item {
    font-size: var(--font-xs);
    color: #991b1b;
    line-height: 1.5;
    padding: 4px 0;
    padding-left: 4px;
}

/* ========================================
   Toast 消息提示
   ======================================== */
.toast-message {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    background: #1e293b;
    color: #fff;
    padding: 12px 24px;
    border-radius: 12px;
    font-size: 14px;
    z-index: 9999;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    pointer-events: none;
    animation: toastIn 0.3s ease;
    white-space: nowrap;
}

.toast-message.toast-hide {
    opacity: 0;
    transition: opacity 0.3s;
}

@keyframes toastIn {
    from { opacity: 0; transform: translateX(-50%) translateY(10px); }
    to { opacity: 1; transform: translateX(-50%) translateY(0); }
}

/* ========================================
   表单字段错误提示
   ======================================== */
.field-error {
    font-size: var(--font-xs);
    color: #dc2626;
    margin-top: 4px;
    padding-left: 2px;
    animation: fieldErrorIn 0.2s ease;
}

.field-error-border {
    border-color: #dc2626 !important;
    box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1) !important;
}

@keyframes fieldErrorIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
}

/* ========================================
   导出按钮
   ======================================== */
.export-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: var(--primary-500);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    font-size: var(--font-sm);
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
    margin-top: var(--spacing-md);
}

.export-btn:hover {
    background: var(--primary-600);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
}

.export-btn:active {
    transform: translateY(0);
}

/* ========================================
   交通对比摘要
   ======================================== */
.summary-compare {
    display: flex;
    gap: var(--spacing-lg);
    margin-top: var(--spacing-sm);
    font-size: var(--font-xs);
    color: var(--text-500);
}

.summary-compare span {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--bg-secondary);
    padding: 3px 10px;
    border-radius: 20px;
}

/* ========================================
   景点信息详细化
   ======================================== */
.attraction-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-sm);
}

.attraction-meta-item {
    font-size: var(--font-xs);
    color: var(--text-500);
    background: var(--bg-secondary);
    padding: 2px 8px;
    border-radius: 10px;
    white-space: nowrap;
}

.attraction-tips {
    margin-top: var(--spacing-sm);
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.attraction-tip {
    font-size: 11px;
    color: var(--primary-600);
    background: var(--primary-50);
    padding: 3px 8px;
    border-radius: 6px;
    line-height: 1.5;
}

/* ========================================
   移动端触控优化
   ======================================== */
@media (hover: none) and (pointer: coarse) {
    .history-actions {
        opacity: 1;
    }

    .history-rename,
    .history-delete {
        width: 32px;
        height: 32px;
    }

    .attraction-item:active {
        transform: scale(0.98);
        background: var(--bg-secondary);
    }

    .food-item:active {
        transform: scale(0.98);
        background: var(--bg-secondary);
    }

    .rest-card:active {
        transform: scale(0.98);
    }

    .transport-option-card:active {
        transform: scale(0.98);
    }
}

/* ========================================
   骨架屏加载
   ======================================== */
.skeleton {
    background: linear-gradient(90deg, var(--bg-secondary) 25%, var(--bg-primary) 50%, var(--bg-secondary) 75%);
    background-size: 200% 100%;
    animation: skeletonShimmer 1.5s infinite;
    border-radius: var(--radius-sm);
}

@keyframes skeletonShimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
}

.skeleton-card {
    padding: var(--spacing-xl);
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-200);
}

.skeleton-title {
    height: 20px;
    width: 40%;
    margin-bottom: var(--spacing-lg);
}

.skeleton-row {
    height: 14px;
    width: 90%;
    margin-bottom: var(--spacing-sm);
}

.skeleton-row.short {
    width: 60%;
}

/* ========================================
   首页底部优化
   ======================================== */
.app-footer {
    text-align: center;
    padding: var(--spacing-xl) 0;
    margin-top: var(--spacing-2xl);
    border-top: 1px solid var(--border-200);
}

.app-footer p {
    font-size: var(--font-xs);
    color: var(--text-400);
    margin: 0;
}

.app-footer .footer-links {
    display: flex;
    justify-content: center;
    gap: var(--spacing-lg);
    margin-top: var(--spacing-sm);
}

.app-footer .footer-links a {
    font-size: var(--font-xs);
    color: var(--text-400);
    text-decoration: none;
    transition: color var(--transition-fast);
}

.app-footer .footer-links a:hover {
    color: var(--primary-500);
}

/* ========================================
   移动端响应式 - 新组件
   ======================================== */
@media (max-width: 768px) {
    .weather-warning-banner {
        padding: var(--spacing-md);
    }

    .summary-compare {
        flex-direction: column;
        gap: var(--spacing-sm);
    }

    .attraction-meta {
        gap: 4px;
    }

    .attraction-meta-item {
        font-size: 10px;
        padding: 2px 6px;
    }

    .attraction-tip {
        font-size: 10px;
    }

    .toast-message {
        bottom: 16px;
        padding: 10px 20px;
        font-size: 13px;
    }

    .history-actions {
        opacity: 1;
    }
}

@media (max-width: 480px) {
    .weather-warning-banner {
        flex-direction: column;
        gap: var(--spacing-sm);
    }

    .export-btn {
        width: 100%;
        justify-content: center;
    }
}
