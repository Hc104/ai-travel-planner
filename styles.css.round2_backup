}

.attraction-badge .max-rating {
    font-size: 0.7rem;
    opacity: 0.8;
}

.attraction-image {
    width: 100px;
    height: 80px;
    flex-shrink: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-secondary);
}

.attraction-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.attraction-info {
    flex: 1;
}

.attraction-name {
    font-weight: 600;
    font-size: var(--font-lg);
    color: var(--text-800);
    margin-bottom: 4px;
}

.attraction-desc {
    font-size: var(--font-sm);
    color: var(--text-500);
    margin-bottom: var(--spacing-md);
