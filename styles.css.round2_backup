}

.step-content {
    flex: 1;
}

.step-title {
    font-weight: 600;
    font-size: var(--font-sm);
    color: var(--text-800);
    margin-bottom: 2px;
}

.step-desc {
    font-size: var(--font-xs);
    color: var(--text-500);
}

.step-duration {
    font-size: var(--font-xs);
    color: var(--primary-600);
