.budget-daily-card-label {
    font-size: var(--font-xs);
    color: var(--text-500);
    margin-bottom: 4px;
}

.budget-daily-card-value {
    font-size: var(--font-lg);
    font-weight: 700;
    color: var(--text-800);
}

.budget-daily-card-unit {
    font-size: 11px;
